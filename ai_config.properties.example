# Copy this file to ai_config.properties in the project root and fill in your values.
# ai_config.properties is gitignored — never commit real keys.

# --- Authentication (use API key OR IAM token) ---
# API key: https://yandex.cloud/en/docs/iam/concepts/authorization/api-key
yandex.api.key=AQVNzTd-FePPoLC5Gut32QEGh9uW_eqe_n2h8KQi

# IAM token (Bearer). Leave empty if using API key.
yandex.iam.token=

# true = use IAM Bearer token; false = use Api-Key header
yandex.use.iam=false

# Yandex Cloud folder ID (required for modelUri)
yandex.folder.id=fvtev5tu2jo5renqmjgh

# Model path after folder id: gpt://{folder-id}/{model}
yandex.model=gpt://b1gkne0tc1mjqdf4ua0l/yandexgpt-5.1/latest

# --- Generation options ---
yandex.temperature=0.3
yandex.max.tokens=2000

# Enable SSE streaming (recommended)
yandex.stream=true
